rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function pendingRequest(requestId) {
      return exists(/databases/$(database)/documents/relationshipRequests/$(requestId))
        && get(/databases/$(database)/documents/relationshipRequests/$(requestId)).data.status == 'pending'
        && get(/databases/$(database)/documents/relationshipRequests/$(requestId)).data.toId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (
        (request.auth.uid == userId && profileFieldsOnly()) ||
        isAdmin() ||
        relationshipAcceptance(userId)
      );
      allow delete: if isAdmin();
    }

    match /relationshipRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.fromId == request.auth.uid
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.status == 'pending';
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow update: if signedIn()
        && request.auth.uid == resource.data.toId
        && request.resource.data.fromId == resource.data.fromId
        && request.resource.data.toId == resource.data.toId
        && request.resource.data.relation == resource.data.relation;
      allow delete: if isAdmin();
    }

    function relationshipAcceptance(userId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let fatherRequest = changed.hasOnly(['fatherId']) && (
        pendingRequest(userId + '_' + request.resource.data.fatherId + '_father') ||
        pendingRequest(request.resource.data.fatherId + '_' + userId + '_child')
      );
      let motherRequest = changed.hasOnly(['motherId']) && (
        pendingRequest(userId + '_' + request.resource.data.motherId + '_mother') ||
        pendingRequest(request.resource.data.motherId + '_' + userId + '_child')
      );
      return fatherRequest || motherRequest;
    }

    function profileFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['fullName', 'birthYear', 'sex', 'photoUrl', 'updatedAt']);
    }
  }
}
